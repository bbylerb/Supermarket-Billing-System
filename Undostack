// Stack — keeps track of added items for Undo feature (LIFO)
public class UndoStack {
    private Item[] stack;
    private int top;
    private static final int MAX_SIZE = 100;

    public UndoStack() {
        stack = new Item[MAX_SIZE];
        top = -1;
    }

    public void push(Item item) {
        if (top < MAX_SIZE - 1) {
            stack[++top] = item;
        }
    }

    public Item pop() {
        if (isEmpty()) return null;
        return stack[top--];
    }

    public Item peek() {
        if (isEmpty()) return null;
        return stack[top];
    }

    public boolean isEmpty() { return top == -1; }
}
