import java.util.Scanner;

public class Main {
    static ShoppingCart cart = new ShoppingCart();
    static UndoStack undoStack = new UndoStack();
    static CustomerQueue customerQueue = new CustomerQueue();
    static Scanner scanner = new Scanner(System.in);

    public static void main(String[] args) {
        System.out.println("==============================");
        System.out.println("   SUPERMARKET BILLING SYSTEM");
        System.out.println("==============================");

        boolean running = true;
        while (running) {
            printMenu();
            System.out.print("Choose option: ");
            String choice = scanner.nextLine().trim();

            switch (choice) {
                case "1": addItem(); break;
                case "2": undoLastItem(); break;
                case "3": viewCart(); break;
                case "4": joinQueue(); break;
                case "5": callNextCustomer(); break;
                case "6": viewQueue(); break;
                case "0": running = false; System.out.println("Goodbye!"); break;
                default: System.out.println("  Invalid option. Try again.");
            }
        }
        scanner.close();
    }

    static void printMenu() {
        System.out.println("\n--- MENU ---");
        System.out.println("1. Add Item to Cart");
        System.out.println("2. Undo Last Item");
        System.out.println("3. View Cart");
        System.out.println("4. Join Checkout Queue");
        System.out.println("5. Call Next Customer (Print Receipt)");
        System.out.println("6. View Queue");
        System.out.println("0. Exit");
    }

    static void addItem() {
        System.out.print("  Item name: ");
        String name = scanner.nextLine();
        System.out.print("  Price: $");
        double price = Double.parseDouble(scanner.nextLine());
        System.out.print("  Quantity: ");
        int qty = Integer.parseInt(scanner.nextLine());

        Item item = new Item(name, price, qty);
        cart.addItem(item);
        undoStack.push(item);
        System.out.println("  Added: " + name);
    }

    static void undoLastItem() {
        if (undoStack.isEmpty()) {
            System.out.println("  Nothing to undo.");
            return;
        }
        Item last = undoStack.pop();
        cart.removeItem(last.getName());
        System.out.println("  Removed: " + last.getName());
    }

    static void viewCart() {
        System.out.println("\n  --- Your Cart ---");
        cart.displayCart();
        System.out.printf("  Total items: %d%n", cart.getSize());
    }

    static void joinQueue() {
    if (cart.isEmpty()) {
        System.out.println("  Your cart is empty. Add items first.");
        return;
    }
    System.out.print("  Enter your name: ");
    String name = scanner.nextLine();
    customerQueue.enqueue(name);
    System.out.println("  " + name + " joined the queue.");
}

    static void callNextCustomer() {
        if (customerQueue.isEmpty()) {
            System.out.println("  No customers in queue.");
            return;
        }
        String customer = customerQueue.dequeue();
        System.out.println("  Now serving: " + customer);
        BillCalculator.printReceipt(customer, cart);
        // Reset cart after checkout
        cart = new ShoppingCart();
        undoStack = new UndoStack();
    }

    static void viewQueue() {
        System.out.println("\n  --- Checkout Queue ---");
        customerQueue.displayQueue();
    }
}
